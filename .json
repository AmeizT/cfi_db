components:
  schemas:
    ActionEnum:
      enum:
      - CREATE
      - UPDATE
      - DELETE
      - RESTORE
      type: string
      description: |-
        * `CREATE` - Create
        * `UPDATE` - Update
        * `DELETE` - Delete
        * `RESTORE` - Restore
    Activation:
      type: object
      properties:
        uid:
          type: string
        token:
          type: string
      required:
      - token
      - uid
    Assembly:
      type: object
      properties:
        name:
          type: string
          maxLength: 100
        country:
          type: string
          maxLength: 100
        avatar_fallback:
          type: string
          maxLength: 36
      required:
      - name
    AssemblyCompliance:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        year:
          type: integer
          maximum: 9223372036854775807
          minimum: 0
          format: int64
        month:
          type: integer
          maximum: 9223372036854775807
          minimum: 0
          format: int64
        status:
          $ref: '#/components/schemas/AssemblyComplianceStatusEnum'
        evaluated_at:
          type: string
          format: date-time
          readOnly: true
        assembly:
          type: integer
        zone:
          type: integer
        report:
          type: integer
          nullable: true
      required:
      - assembly
      - evaluated_at
      - id
      - month
      - status
      - year
      - zone
    AssemblyComplianceStatusEnum:
      enum:
      - COMPLIANT
      - LATE
      - NOT_SUBMITTED
      - NOT_FINALIZED
      - MISSING_FROM_ZONE
      type: string
      description: |-
        * `COMPLIANT` - Compliant
        * `LATE` - Late
        * `NOT_SUBMITTED` - Not Submitted
        * `NOT_FINALIZED` - Not Finalized
        * `MISSING_FROM_ZONE` - Missing From Zone
    AssemblyISO:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        country_code:
          type: string
          maxLength: 3
        language:
          type: string
          maxLength: 12
        currency:
          type: string
          maxLength: 12
      required:
      - id
    AssemblyReport:
      type: object
      description: |-
        Base serializer that generates:
        - url: self-detail URL
        - links: related object URLs
        - actions: edit/delete/bulk-delete URLs
        - collection_actions: bulk delete/restore URLs
        Permissions are omitted since authenticated users have full access.
      properties:
        id:
          type: integer
          readOnly: true
        assembly:
          type: integer
        period_start:
          type: string
          format: date
        period_end:
          type: string
          format: date
        status:
          $ref: '#/components/schemas/AssemblyReportStatusEnum'
        attendance_total:
          type: integer
          maximum: 9223372036854775807
          minimum: -9223372036854775808
          format: int64
        income_total:
          type: string
          format: decimal
          pattern: ^-?\d{0,12}(?:\.\d{0,2})?$
        expense_total:
          type: string
          format: decimal
          pattern: ^-?\d{0,12}(?:\.\d{0,2})?$
        tithe_total:
          type: string
          format: decimal
          pattern: ^-?\d{0,12}(?:\.\d{0,2})?$
        balance:
          type: string
          format: decimal
          pattern: ^-?\d{0,12}(?:\.\d{0,2})?$
        members_total:
          type: integer
          maximum: 9223372036854775807
          minimum: -9223372036854775808
          format: int64
        finalized_at:
          type: string
          format: date-time
          nullable: true
        url:
          type: string
          readOnly: true
      required:
      - assembly
      - id
      - period_end
      - period_start
      - url
    AssemblyReportStatusEnum:
      enum:
      - draft
      - finalized
      - reviewed
      - approved
      - archived
      type: string
      description: |-
        * `draft` - Draft
        * `finalized` - Finalized
        * `reviewed` - Reviewed
        * `approved` - Approved
        * `archived` - Archived
